# =========================================================================
# WHMS System Testing Database Environment Variables
# =========================================================================

# MySQL Root Password
MYSQL_ROOT_PASSWORD=whms_root_secure_password_2026

# MySQL Database Name
MYSQL_DATABASE=whms_db

# MySQL Username and Password
MYSQL_USER=whms_user
MYSQL_PASSWORD=whms_user_password_2026

# Database Port (External port exposed to host)
DB_PORT=3307

# phpMyAdmin Port (External port exposed to host)
PMA_PORT=8081

# Prisma DATABASE_URL configuration
# For prisma running on host, connect to localhost:DB_PORT
DATABASE_URL=mysql://whms_user:whms_user_password_2026@localhost:3307/whms_db
